OPENAI_API_KEY=your_key_here

# LangSmith tracing (optional)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
# LANGCHAIN_PROJECT=trade-exception-review-agent

# Review policy configuration
# CONFIDENCE_AUTO_APPROVE_THRESHOLD=0.85
# AMOUNT_ALWAYS_REVIEW_THRESHOLD=1000000

# Checkpointer backend
# LANGGRAPH_CHECKPOINTER=memory
# LANGGRAPH_CHECKPOINTER_POSTGRES_URL=postgresql://user:pass@localhost:5432/trade_agent
